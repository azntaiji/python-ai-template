## Task 1 - Create the app factory and routes

**Files:** `src/zach_taiji_blog/app.py`

**Steps:**

1. Create `src/zach_taiji_blog/app.py` with exactly:

```python
"""Flask application factory and routes for the blog."""

import logging
from pathlib import Path

from flask import Flask, abort, render_template

from zach_taiji_blog import config
from zach_taiji_blog.posts import collect_tags, load_all_posts, load_post
from zach_taiji_blog.site_config import load_site_config

logger = logging.getLogger(__name__)


def create_app(
    blogs_dir: Path | None = None,
    site_config_path: Path | None = None,
) -> Flask:
    """Create the blog's Flask application.

    Args:
        blogs_dir: Directory of markdown posts; defaults to
            config.BLOGS_DIR ("blogs").
        site_config_path: TOML site configuration file; defaults to
            config.SITE_CONFIG_PATH ("site.toml").

    Returns:
        The configured Flask app.
    """
    app = Flask(__name__)
    posts_root = Path(blogs_dir) if blogs_dir else Path(config.BLOGS_DIR)
    cfg_path = (
        Path(site_config_path)
        if site_config_path
        else Path(config.SITE_CONFIG_PATH)
    )

    @app.context_processor
    def inject_site_context() -> dict:
        """Make site config and nav tags available to every template."""
        return {
            "site": load_site_config(cfg_path),
            "nav_tags": collect_tags(load_all_posts(posts_root)),
        }

    @app.route("/")
    def index() -> str:
        return render_template("index.html", posts=load_all_posts(posts_root))

    @app.route("/post/<slug>")
    def post_page(slug: str) -> str:
        path = posts_root / f"{slug}.md"
        if not path.is_file():
            abort(404)
        return render_template("post.html", post=load_post(path))

    @app.route("/tag/<tag>")
    def tag_page(tag: str) -> str:
        posts = [p for p in load_all_posts(posts_root) if tag in p.tags]
        return render_template("tag.html", tag=tag, posts=posts)

    @app.errorhandler(404)
    def not_found(err: object) -> tuple[str, int]:
        return render_template("404.html"), 404

    return app
```

