"""Tests for zach_taiji_blog.app."""

from pathlib import Path

import pytest
from flask.testing import FlaskClient

from zach_taiji_blog.app import create_app

POST = """---
title: Test Post
date: 2026-01-02
tags:
  - alpha
---

Hello ==bright== world.
"""

SITE = """[site]
title = "Test Blog"

[[menu]]
label = "Elsewhere"
url = "https://example.com"

[footer]
copyright = "© Test"
"""


@pytest.fixture()
def client(tmp_path: Path) -> FlaskClient:
    blogs = tmp_path / "blogs"
    blogs.mkdir()
    (blogs / "test-post.md").write_text(POST)
    site = tmp_path / "site.toml"
    site.write_text(SITE)
    app = create_app(blogs_dir=blogs, site_config_path=site)
    app.config["TESTING"] = True
    return app.test_client()


def test_index_lists_posts(client: FlaskClient) -> None:
    body = client.get("/").text
    assert "Test Blog" in body
    assert "Test Post" in body
    assert "Elsewhere" in body


def test_post_page_renders_markdown(client: FlaskClient) -> None:
    body = client.get("/post/test-post").text
    assert "<mark>bright</mark>" in body
    assert "© Test" in body


def test_unknown_slug_404(client: FlaskClient) -> None:
    resp = client.get("/post/does-not-exist")
    assert resp.status_code == 404
    assert "404" in resp.text


def test_tag_page_filters(client: FlaskClient) -> None:
    assert "Test Post" in client.get("/tag/alpha").text
    assert "Test Post" not in client.get("/tag/beta").text
```

