"""Command-line interface for the zach_taiji_blog package."""

import argparse

from zach_taiji_blog.app import create_app
from zach_taiji_blog.logging_config import setup_logging


def main() -> None:
    """Run the blog's local development server."""
    setup_logging()
    parser = argparse.ArgumentParser(
        prog="zach_taiji_blog",
        description="Serve the markdown blog locally.",
    )
    parser.add_argument("--host", default="127.0.0.1", help="Bind address")
    parser.add_argument("--port", type=int, default=5000, help="Port (default 5000)")
    parser.add_argument("--debug", action="store_true", help="Enable Flask debug mode")
    args = parser.parse_args()
    create_app().run(host=args.host, port=args.port, debug=args.debug)


if __name__ == "__main__":
    main()
```

